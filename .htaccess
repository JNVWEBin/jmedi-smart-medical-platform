Options -Indexes
Options -MultiViews

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # Home
    RewriteRule ^$ public/index.php [L]

    # Redirect bare index.php to home
    RewriteRule ^index\.php$ / [L,R=301]

    # Pass through real files and directories (assets, admin, public, etc.)
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Route clean single-segment URLs to public/NAME.php
    # e.g. /doctors → public/doctors.php, /blog → public/blog.php
    RewriteCond %{DOCUMENT_ROOT}/public/%1.php -f
    RewriteRule ^([^/]+)/?$ public/$1.php [L,QSA]

    # Fallback — send everything else to public/index.php (handles its own 404)
    RewriteRule ^(.*)$ public/index.php [L,QSA]
</IfModule>

<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

<FilesMatch "\.(env|log|sql|sh|bak)$">
    Order allow,deny
    Deny from all
</FilesMatch>

<IfModule mod_php.c>
    php_flag display_errors Off
    php_value error_reporting 0
    php_flag log_errors On
</IfModule>

<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css text/javascript application/javascript
</IfModule>

<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpeg "access plus 1 month"
    ExpiresByType image/png "access plus 1 month"
    ExpiresByType image/webp "access plus 1 month"
    ExpiresByType text/css "access plus 1 week"
    ExpiresByType application/javascript "access plus 1 week"
</IfModule>
